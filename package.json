{
  "name": "scanit",
  "private": true,
  "version": "0.0.1",
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "pnpm@10.24.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "eval:dataset": "node scripts/eval-dataset.mjs",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
    "test": "pnpm run lint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "studio": "pnpm exec sanity dev",
    "benchmark": "node scripts/benchmark.js",
    "capture:dataset": "node scripts/capture-dataset.js",
    "capture:video": "node scripts/capture-dataset.js --video-only",
    "replay:ensemble": "tsx scripts/replay-ensemble.ts",
    "replay:ensemble:impute-video": "tsx scripts/replay-ensemble.ts --impute-video"
  },
  "devDependencies": {
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.68.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^25.9.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "sanity": "^5.17.1",
    "svelte": "^5.51.0",
    "svelte-check": "^4.4.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@sanity/client": "^7.20.0",
    "@sanity/image-url": "^2.0.3",
    "exifr": "^7.1.3",
    "face-api.js": "^0.22.2",
    "groq-sdk": "^1.1.2",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "mediainfo.js": "^0.3.7",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "5.5.207",
    "tesseract.js": "^7.0.0"
  },
  "pnpm": {
    "overrides": {
      "@sanity/uuid>uuid": "11.1.1",
      "@sveltejs/kit>cookie": "0.7.2",
      "@tensorflow/tfjs-core>node-fetch": "2.7.0",
      "@vercel/frameworks>js-yaml": "3.14.2",
      "typeid-js>uuid": "11.1.1"
    }
  }
}
