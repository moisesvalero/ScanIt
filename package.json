{
	"name": "novakit",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"studio": "npx sanity dev",
		"benchmark": "node scripts/benchmark.js",
		"capture:dataset": "node scripts/capture-dataset.js",
		"capture:video": "node scripts/capture-dataset.js --video-only",
		"replay:ensemble": "tsx scripts/replay-ensemble.ts",
		"replay:ensemble:impute-video": "tsx scripts/replay-ensemble.ts --impute-video"
	},
	"devDependencies": {
		"@sanity/cli": "^6.2.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"autoprefixer": "^10.4.27",
		"playwright": "^1.58.2",
		"postcss": "^8.5.8",
		"sanity": "^5.17.1",
		"svelte": "^5.51.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@sanity/client": "^7.20.0",
		"@sanity/image-url": "^2.0.3",
		"exifr": "^7.1.3",
		"face-api.js": "^0.22.2",
		"jspdf": "^4.2.1",
		"mediainfo.js": "^0.3.7"
	}
}
